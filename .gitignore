# Package manager locks (keep these!)
# ✅ KEEP: package-lock.json, yarn.lock, pnpm-lock.yaml

# ============================================
# ✅ FILES TO KEEP (Don't ignore these)
# ============================================
# !.gitignore
# !README.md
# !package.json
# !tsconfig.json
# !next.config.js
# !postcss.config.js
# !tailwind.config.ts