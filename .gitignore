# ============================================
# 🔐 ENVIRONMENT VARIABLES (SENSITIVE)
# ============================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
!.env.example

# API Keys & Credentials (NEVER commit these)
google-credentials.json
service-account-key.json
*.pem
*.key
*.crt
secrets.json
config.json

